# Copy this file to .env and fill in your values
# cp .env.example .env

# Azure AI Foundry — Cohere Embed endpoint
# base_url = Target URI up to /providers/cohere (exclude /v2/embed)
EMBED_MODEL=embed-v-4-0
EMBED_BASE_URL=https://<your-embed-endpoint>.services.ai.azure.com/providers/cohere
EMBED_API_KEY=<your-embed-api-key>

# Azure AI Foundry — Cohere Rerank endpoint
# base_url = Target URI up to /providers/cohere (exclude /v2/rerank)
RERANK_MODEL=Cohere-rerank-v4.0-pro
RERANK_BASE_URL=https://<your-rerank-endpoint>.services.ai.azure.com/providers/cohere
RERANK_API_KEY=<your-rerank-api-key>

# ChromaDB storage path (default is fine)
CHROMA_DB_PATH=./chroma_db